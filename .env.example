# Vigil - Environment Variables

# Security
SECRET_KEY=change-this-in-production-to-a-random-string

# Stripe (Global payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# PayMongo (Philippines - GCash, Maya, GrabPay)
PAYMONGO_SECRET_KEY=sk_test_your_paymongo_secret_key
PAYMONGO_WEBHOOK_SECRET=whsec_your_paymongo_webhook_secret
PAYMONGO_PUBLIC_KEY=pk_test_your_paymongo_public_key

# SendGrid (Email)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
FROM_EMAIL=alerts@example.com
FROM_NAME=Vigil Security

# GitHub (Terraform PRs)
GITHUB_TOKEN=ghp_your_github_token
